{
  "name": "flaky-test-detective",
  "version": "1.0.0",
  "description": "Detect, track, and quarantine flaky tests with pattern analysis and trend reporting",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js"
    }
  },
  "bin": {
    "flaky-detective": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write \"**/*.ts\"",
    "format:check": "prettier --check \"**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm test && npm run build"
  },
  "keywords": ["flaky", "test", "detective", "playwright", "junit", "quarantine", "ci", "testing", "quality"],
  "author": "Quvantic <info@quvantic.com> (https://quvantic.com)",
  "license": "MIT",
  "repository": { "type": "git", "url": "https://github.com/mustafaautomation/flaky-test-detective.git" },
  "homepage": "https://github.com/mustafaautomation/flaky-test-detective#readme",
  "bugs": { "url": "https://github.com/mustafaautomation/flaky-test-detective/issues" },
  "dependencies": {
    "commander": "^12.1.0",
    "dotenv": "^16.4.7",
    "fast-xml-parser": "^4.5.1",
    "sql.js": "^1.11.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/sql.js": "^1.4.9",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.3.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "engines": { "node": ">=18.0.0" },
  "files": ["dist"]
}
